# ============================================================
# BACKEND (.env in /workspaces/Felix/backend/)
# ============================================================

# Google OAuth — from GCP Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GCP
GCP_PROJECT_ID=felix-personal-xxxxx
GCP_REGION=europe-west2

# AI — Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# Voice — ElevenLabs
ELEVENLABS_API_KEY=xxxx
FELIX_VOICE_ID=xxxx

# Supabase (service key — backend only, never expose to frontend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=xxxx

# Direct Postgres URL — from Supabase: Settings → Database → Connection string
# Use the "Session mode" pooler URL (port 5432) for asyncpg
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# Token encryption — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=xxxx

# App
BACKEND_SECRET_KEY=xxxx
FRONTEND_URL=http://localhost:3000

# ============================================================
# FRONTEND (.env.local in /workspaces/Felix/frontend/)
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
